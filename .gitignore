# Local resume inputs
input/*
!input/README.md

# Local workflow state is uncommitted by default; commit only guide/template files.
workflow_state/*
!workflow_state/.gitkeep
!workflow_state/README.md
!workflow_state/*.template.md
!workflow_state/fresh_job_jds/
workflow_state/fresh_job_jds/*
!workflow_state/fresh_job_jds/.gitkeep

# Real evidence is uncommitted by default; commit only guide/template files.
evidence/**
!evidence/
!evidence/README.md
!evidence/work/
!evidence/work/README.md
!evidence/work/*TEMPLATE*.md
!evidence/work/*.template.json
!evidence/projects/
!evidence/projects/README.md
!evidence/projects/*TEMPLATE*.md

# Real role briefs are uncommitted by default; commit only guide/template files.
Gmail/role_briefs/**
!Gmail/role_briefs/
!Gmail/role_briefs/README.md
!Gmail/role_briefs/*TEMPLATE*.md

# Optional local resume inputs that users commonly create while running the workflow
master_resume.tex
*.local.tex
scripts/build-task.json

# Generated output
output/*
!output/.gitkeep
!output/tailored_tex/
!output/pdfs/
output/tailored_tex/*
output/pdfs/*
!output/tailored_tex/.gitkeep
!output/pdfs/.gitkeep

# Resume artifacts
*.pdf
*.docx
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.run.xml
*.synctex.gz
*.xdv
texput.log

# Local working files
JD Text.md

# Custom fonts — drop .ttf/.otf files here for xelatex/lualatex builds
# The fonts/ folder itself is committed (via .gitkeep); font files are not
fonts/*
!fonts/.gitkeep

# Sensitive local files
.env
.env.*
credentials.json
token.json
*.pem
*.key
*.p12
*.pfx

# MCP server — local config, credentials, build output, and generated index
mcp-server/config.json
mcp-server/credentials.json
mcp-server/gmail-token.json
mcp-server/dist/
mcp-server/node_modules/
mcp-server/evidence_index.json

# Private tools — personal tracking and networking sheets, not for public repo
mcp-server/src/index.local.ts
mcp-server/src/tools/scanRejections.ts
mcp-server/src/tools/writeNetworkingRows.ts
mcp-server/src/tools/writeOutliersRows.ts
mcp-server/src/tools/linkedinSearchPool.ts
mcp-server/src/tools/linkedinActivityCheck.ts

# career_scan — private job discovery tool, not for public repo
mcp-server/src/tools/careerScan/
mcp-server/src/tools/careerScan/snapshots/

# commentDrafter — private LinkedIn post comment tool, not for public repo
mcp-server/src/tools/commentDrafter/
mcp-server/src/tools/commentDrafter/snapshots/

# Common generated/local workflow folders
role_briefs/
Tailored PDFs/
Tailored Texs/
The Master Resume*/

# Editor and OS noise
.DS_Store
Thumbs.db
.vscode/
.idea/
