{
  "name": "resume-tailoring-mcp",
  "version": "1.0.0",
  "description": "MCP server for the resume-tailoring-workflow — exposes job search, JD processing, tracker updates, resume compilation, and Gmail outreach as tools for any MCP-compatible AI assistant.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:local": "tsc && node -e \"require('fs').copyFileSync('dist/index.local.js','dist/index.js')\"",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.4.2",
    "googleapis": "^173.0.0",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
